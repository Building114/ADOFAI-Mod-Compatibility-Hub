  <Target Name="ValidateGameDirForOverlayerXDBuilding" BeforeTargets="ResolveReferences" Condition="'$(GameDir)' == ''">
    <Error Text="GameDir is not set. Set ADOFAI_GAME_DIR, pass /p:GameDir=..., or create Local.Build.props from Local.Build.props.example." />
  </Target>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <PropertyGroup>
    <PostBuildEvent>
    if /I "$(DeployToGame)"=="true" (
      if not exist "$(ModDir)" mkdir "$(ModDir)"
      if not exist "$(ModDir)\lang" mkdir "$(ModDir)\lang"
      if not exist "$(ModDir)\lib" mkdir "$(ModDir)\lib"
      copy /Y "$(TargetPath)" "$(ModDir)\Overlayer.dll"
      xcopy /Y /I /S /E "$(ProjectDir)MiscFiles\lang\*" "$(ModDir)\lang\"
      xcopy /Y /I "$(ProjectDir)MiscFiles\info.json" "$(ModDir)\"
      xcopy /Y /I "$(ProjectDir)MiscFiles\update.txt" "$(ModDir)\"
      xcopy /Y /I "$(ProjectDir)MiscFiles\ov3_logo.png" "$(ModDir)\"
      del /Q "$(ModDir)\lib\*.dll" 2&gt;nul
      for %%F in ("$(TargetDir)*.dll") do (
        if /I not "%%~nxF"=="Overlayer.dll" copy /Y "%%~fF" "$(ModDir)\lib\"
      )
    ) else (
      echo DeployToGame is false; skipping copy to local ADOFAI Mods folder.
    )
    </PostBuildEvent>
  </PropertyGroup>
